{
  "api_version": "v20250920",
  "commands": {
    "instance.create": {
      "short": "Create a new sandbox instance",
      "long": "Create a new sandbox instance from a tool template.\n\nThe referenced tool must already exist. Create one first with `agr tool create`, or pass an existing --tool-id.\n\nUse --tool-name/-t for tool name or --tool-id for tool ID.\n\nComplex API fields such as --mount-options, --metadata, and --custom-configuration accept JSON, @file, or - for stdin.\n\nAuth mode (--auth-mode):\n  DEFAULT  Use backend default (currently TOKEN)\n  TOKEN    All ports require X-Access-Token\n  PUBLIC   envd management port (49983) requires token; other ports open\n  NONE     No authentication on any port",
      "examples": [
        "agr instance create --tool-id sdt-xxxx",
        "agr instance create --tool-name my-tool",
        "agr instance create -t my-tool --timeout 5m",
        "agr instance create --tool-id sdt-xxxx --mount-options '[{\"Name\":\"data\",\"MountPath\":\"/workspace\"}]'",
        "agr instance create -t my-tool --auth-mode NONE"
      ],
      "fields": {
        "ToolName": {
          "description": "Tool name.",
          "inputs": {
            "tool-name": {
              "usage": "Tool name"
            }
          }
        },
        "ToolId": {
          "description": "Tool ID.",
          "inputs": {
            "tool-id": {
              "usage": "Tool ID"
            }
          }
        },
        "Timeout": {
          "description": "Instance timeout.",
          "inputs": {
            "timeout": {
              "usage": "Instance timeout as accepted by the API, for example 5m, 300s, or 1h"
            }
          }
        },
        "MountOptions": {
          "description": "Storage mount options for the instance.",
          "inputs": {
            "mount-options": {
              "usage": "MountOptions as JSON array, @file, or - for stdin"
            }
          }
        },
        "CustomConfiguration": {
          "description": "Custom configuration for the sandbox instance.",
          "inputs": {
            "custom-configuration": {
              "usage": "CustomConfiguration JSON object, @file, or - for stdin"
            }
          }
        },
        "Metadata": {
          "description": "Instance metadata.",
          "inputs": {
            "metadata": {
              "usage": "Metadata as JSON array, @file, or - for stdin"
            }
          }
        },
        "AuthMode": {
          "description": "Sandbox access authentication mode.",
          "inputs": {
            "auth-mode": {
              "usage": "Auth mode: DEFAULT, TOKEN, NONE, PUBLIC",
              "values": [
                "DEFAULT",
                "TOKEN",
                "NONE",
                "PUBLIC"
              ]
            }
          }
        },
        "ClientToken": {
          "description": "Client token for duplicate creation protection.",
          "inputs": {
            "client-token": {
              "usage": "Client token for duplicate creation protection"
            }
          }
        }
      }
    },
    "instance.list": {
